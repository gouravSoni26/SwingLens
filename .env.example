# Claude API (primary provider)
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Groq API (free fallback)
# Get from: console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# Obsidian Local REST API
# Get from: Obsidian → Settings → Community Plugins → Local REST API → API Key
OBSIDIAN_API_KEY=your-obsidian-key-here
OBSIDIAN_HOST=localhost

# Telegram capture bot (Phase 4)
# TELEGRAM_BOT_TOKEN: from @BotFather (/newbot)
# TELEGRAM_ALLOWED_CHAT_ID: your numeric chat ID (message @userinfobot) — only this chat is accepted
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_CHAT_ID=your-numeric-chat-id
